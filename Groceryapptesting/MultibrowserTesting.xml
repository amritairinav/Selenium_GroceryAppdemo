<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="MultibrowserSuite">
	<listeners>
		<listener class-name="generatereport.Listeners" />
	</listeners>

	<test name="ChromeTest">
		<parameter name="browser" value="chrome" />
		<classes>
			<class name="testscript.LoginTestCase" />
			<class name="testscript.LogoutTestCase" />
			<class name="testscript.AddNewsTestCase" />
			<class name="testscript.AdminUserTestCase" />
			<class name="testscript.ManageCategoryTestcase" />
			<class name="testscript.ManageFooterTestCase" />
			<class name="testscript.MananageContactsTestCase" />
		</classes>
	</test>

	<test name="EdgeTest">
		<parameter name="browser" value="edge" />
		<classes>
			<class name="testscript.LoginTestCase" />
			<class name="testscript.LogoutTestCase" />
			<class name="testscript.AddNewsTestCase" />
			<class name="testscript.AdminUserTestCase" />
			<class name="testscript.ManageCategoryTestcase" />
			<class name="testscript.ManageFooterTestCase" />
			<class name="testscript.MananageContactsTestCase" />
		</classes>
	</test>

</suite>



